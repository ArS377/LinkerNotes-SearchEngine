PORT=3000

# MusicBrainz requires a descriptive contact value in the User-Agent.
MUSICBRAINZ_CONTACT=https://github.com/ArS377/SearchEngine

# Optional: resolves exact Spotify track URLs through the official Web API.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional: enables uploaded audio and humming identification.
ACRCLOUD_HOST=
ACRCLOUD_ACCESS_KEY=
ACRCLOUD_ACCESS_SECRET=
